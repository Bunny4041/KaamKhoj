# ── App ──────────────────────────────────────────
APP_NAME=KaamKhoj
APP_ENV=development           # development | production
DEBUG=true
FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/kaamkhoj
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/kaamkhoj

# ── Auth / JWT ───────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis (notifications / rate limiting) ────────
REDIS_URL=redis://localhost:6379/0

# ── Email (SMTP) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_NAME=KaamKhoj
EMAILS_FROM_EMAIL=noreply@kaamkhoj.in

# ── File Uploads ─────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# ── Pagination defaults ──────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
